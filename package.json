{
  "version": "0.1.0",
  "name": "gridsome-source-wikidata",
  "description": "Wikidata source for Gridsome",
  "homepage": "https://github.com/hunsalz/gridsome-source-wikidata",
  "main": "index.js",
  "types": "index.d.ts",
  "author": "Markus Hunsalz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hunsalz/gridsome-source-wikidata.git"
  },
  "bugs": {
    "url": "https://github.com/hunsalz/gridsome-source-wikidata/issues"
  },
  "keywords": [
    "gridsome",
    "gridsome-plugin",
    "gridsome-source",
    "wikidata"
  ],
  "peerDependencies": {
    "gridsome": "^0.7.0 || ^1.0.0"
  },
  "peerDependenciesMeta": {
    "gridsome": {
      "optional": true
    }
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "fs-extra": "^11.3.4",
    "got": "^15.0.2",
    "rev-hash": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\""
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ]
  },
  "lint-staged": {
    "*.{js,json,md}": "prettier --write"
  }
}
